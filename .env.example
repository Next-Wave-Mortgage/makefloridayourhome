# Google Analytics 4
GA4_ID=G-XXXXXXXXXX

# GoHighLevel Private Integration (API v2)
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=xxxxxxxxxxxxxxxxxxxxxxx

# Vercel deployment URL (auto-set by Vercel, but useful locally)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# FRED API (used for public Freddie Mac / FRED mortgage benchmark rates)
FRED_API_KEY=your_fred_api_key_here

# Gemini API (used to generate the mortgage rates market note)
GEMINI_API_KEY=your_gemini_api_key_here

# Vercel Cron authorization
CRON_SECRET=replace_with_random_secret

# Vercel Blob durable storage for the mortgage rates snapshot
BLOB_READ_WRITE_TOKEN=vercel_blob_read_write_token_here
